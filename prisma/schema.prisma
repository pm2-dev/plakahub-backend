generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  role          Role     @default(USER)
  expoPushToken String?  @map("expo_push_token")
  avatarUrl     String?  @map("avatar_url")
  carBrand      String?  @map("car_brand")
  carModel      String?  @map("car_model")
  carYear       String?  @map("car_year")
  createdAt     DateTime @default(now())

  plates               Plate[]
  socialProfiles       SocialProfile[]
  conversationsAsUser1 Conversation[]  @relation("user1")
  conversationsAsUser2 Conversation[]  @relation("user2")
  sentMessages         Message[]
  blockedUsers         BlockedUser[]   @relation("blocker")
  blockedByUsers       BlockedUser[]   @relation("blocked")

  @@map("users")
}

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("blocked_users")
}

model Conversation {
  id        String   @id @default(cuid())
  user1Id   String   @map("user1_id")
  user2Id   String   @map("user2_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user1    User      @relation("user1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("user2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model Plate {
  id          String  @id @default(cuid())
  plateNumber String  @unique @map("plate_number")
  isVerified  Boolean @default(false) @map("is_verified")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([plateNumber])
  @@map("plates")
}

model SocialProfile {
  id       String  @id @default(cuid())
  platform String
  username String
  isHidden Boolean @default(false) @map("is_hidden")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, platform])
  @@index([userId])
  @@map("social_profiles")
}
